# Database Configuration
DB_NAME=ekidna_db
DB_USER=ekidna_user
DB_PASSWORD=changeme123

# Backend Configuration
NODE_ENV=production
PORT=3001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Email Configuration
# See backend/EMAIL_SETUP.md for detailed setup instructions
#
# For Brevo (recommended, free tier available):
#   1. Create account at https://www.brevo.com
#   2. Verify your sender email/domain
#   3. Generate SMTP key at https://app.brevo.com/settings/keys/smtp
#   4. Use your Brevo account email for EMAIL_USER
#   5. Use the generated SMTP key (starts with xsmtpsib-) for EMAIL_PASSWORD
#
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-brevo-account-email@example.com
EMAIL_PASSWORD=your-brevo-smtp-key-here-starts-with-xsmtpsib
EMAIL_FROM=noreply@ekidna.org
#
# Note: EMAIL_FROM must be a verified sender in your Brevo account
# To test: run "node backend/test-smtp.js" after configuration

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Admin User (created on first migration)
ADMIN_EMAIL=admin@ekidna.org
ADMIN_PASSWORD=admin123
